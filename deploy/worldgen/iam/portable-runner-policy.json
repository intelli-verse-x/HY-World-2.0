{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadRegionalModelCache",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": [
        "arn:aws:s3:::intelliverse-hyworld-private-us-east-1",
        "arn:aws:s3:::intelliverse-hyworld-private-us-west-2"
      ],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "models/hy-world/hf/*",
            "worldgen-full-checkpoints/*",
            "worldgen-full-staging/*",
            "worldgen-full-ops/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadModelsAndDurableState",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::intelliverse-hyworld-private-us-east-1/models/hy-world/hf/*",
        "arn:aws:s3:::intelliverse-hyworld-private-us-east-1/worldgen-full-checkpoints/*",
        "arn:aws:s3:::intelliverse-hyworld-private-us-east-1/worldgen-full-staging/*",
        "arn:aws:s3:::intelliverse-hyworld-private-us-east-1/worldgen-full-ops/*",
        "arn:aws:s3:::intelliverse-hyworld-private-us-west-2/models/hy-world/hf/*"
      ]
    },
    {
      "Sid": "WriteAtomicCentralCheckpoints",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:DeleteObject",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::intelliverse-hyworld-private-us-east-1/worldgen-full-checkpoints/*",
        "arn:aws:s3:::intelliverse-hyworld-private-us-east-1/worldgen-full-staging/*",
        "arn:aws:s3:::intelliverse-hyworld-private-us-east-1/worldgen-full-ops/*"
      ]
    },
    {
      "Sid": "PullRegionalWorkerImage",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "PullRegionalWorkerLayers",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer"
      ],
      "Resource": [
        "arn:aws:ecr:us-east-2:970547373533:repository/hy-world-full-worker",
        "arn:aws:ecr:us-west-2:970547373533:repository/hy-world-full-worker"
      ]
    },
    {
      "Sid": "ReadPortableRunnerSecrets",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:us-west-2:970547373533:secret:hy-world/portable-runner-*"
    },
    {
      "Sid": "InspectRunner",
      "Effect": "Allow",
      "Action": "ec2:DescribeInstances",
      "Resource": "*"
    },
    {
      "Sid": "TerminateTaggedSelf",
      "Effect": "Allow",
      "Action": "ec2:TerminateInstances",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ec2:ResourceTag/ManagedBy": "hy-world-fullstack"
        }
      }
    }
  ]
}
